{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "match_manager/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "backend/server.js" },
    {
      "source": "/assets/(.*)",
      "destination": "/match_manager/assets/$1"
    },
    {
      "source": "/vite.svg",
      "destination": "/match_manager/vite.svg"
    },
    { "source": "/((?!api/).*)", "destination": "/match_manager/index.html" }
  ]
}
   